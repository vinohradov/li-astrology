---
import Layout from './Layout.astro';
import { site } from '@/config/site';

interface Props {
  title: string;
  updated?: string;
  description?: string;
}
const { title, updated, description } = Astro.props;
---

<Layout title={`${title} — ${site.name}`} description={description} noindex>
  <section class="relative pt-40 pb-12 md:pt-48 gradient-night text-cream">
    <div class="noise-overlay absolute inset-0 opacity-[0.04]"></div>
    <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(232,201,135,0.12)_0%,transparent_60%)]"></div>

    <div class="relative mx-auto max-w-3xl px-6 md:px-10">
      <a href="/" class="mb-10 inline-flex items-center gap-2 text-xs uppercase tracking-[0.3em] text-cream/60 hover:text-cream">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        На головну
      </a>
      <div class="mb-4 flex items-center gap-3 text-xs uppercase tracking-[0.4em] text-gold-bright/80">
        <span class="h-px w-10 bg-gold-bright/60"></span>
        <span>Правова інформація</span>
      </div>
      <h1 class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.05] tracking-tight text-balance">
        {title}
      </h1>
      {updated && (
        <p class="mt-4 text-xs uppercase tracking-[0.25em] text-cream/50">
          Востаннє оновлено: {updated}
        </p>
      )}
    </div>
  </section>

  <section class="relative py-16 md:py-24">
    <div class="mx-auto max-w-3xl px-6 md:px-10">
      <article class="prose-legal space-y-6 text-[15.5px] leading-[1.7] text-ink/90">
        <slot />
      </article>

      <div class="mt-16 rounded-2xl border border-ink/10 bg-cream-soft p-6 text-sm text-ink-muted">
        <div class="font-display text-lg text-ink">Контакт для правових питань</div>
        <p class="mt-2">
          <strong>{site.legal.entityFull}</strong>
          <br />
          Email: <a href={`mailto:${site.contact.email}`} class="text-gold-deep underline-offset-4 hover:underline">{site.contact.email}</a>
          <br />
          Telegram: <a href={site.bot.url} target="_blank" rel="noopener" class="text-gold-deep underline-offset-4 hover:underline">@{site.bot.username}</a>
        </p>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .prose-legal h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-ink);
  }
  .prose-legal h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.3;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-ink);
  }
  .prose-legal p {
    margin-bottom: 0.75rem;
  }
  .prose-legal ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .prose-legal ol {
    list-style: decimal;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .prose-legal li {
    margin-bottom: 0.35rem;
  }
  .prose-legal strong {
    color: var(--color-ink);
    font-weight: 600;
  }
  .prose-legal a {
    color: var(--color-gold-deep);
    text-underline-offset: 4px;
  }
  .prose-legal a:hover {
    text-decoration: underline;
  }
</style>
