---
import { site } from '@/config/site';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Головна' },
  { href: '/intensiv/', label: 'Інтенсив' },
  { href: '/aspekty/', label: 'Аспекти' },
  { href: '/course/', label: 'Курс' },
];

const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="absolute inset-x-0 top-0 z-50 text-cream">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-6 py-6 md:px-10 md:py-7">
    <!-- Brand -->
    <a href="/" class="group flex items-center gap-3">
      <Logo class="h-10 w-10 transition-transform duration-700 group-hover:rotate-[12deg]" />
      <span class="font-display text-xl leading-none tracking-wide text-cream">
        Li <span class="italic text-gold-bright">Astrology</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex">
      {nav.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <a
            href={href}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'relative rounded-full px-4 py-2 text-sm font-medium tracking-wide transition-colors duration-300',
              active
                ? 'text-ink'
                : 'text-cream/75 hover:text-cream',
            ]}
          >
            {active && (
              <span aria-hidden="true" class="absolute inset-0 -z-10 rounded-full bg-gold-bright"></span>
            )}
            <span class="relative">{label}</span>
          </a>
        );
      })}
    </nav>

    <!-- Right cluster: lang + telegram + mobile menu -->
    <div class="flex items-center gap-3">
      <!-- Language switcher -->
      <div
        id="lang-switcher"
        class="hidden items-center gap-1 rounded-full border border-cream/20 bg-white/5 p-1 text-[11px] font-semibold uppercase tracking-widest backdrop-blur md:inline-flex"
        role="group"
        aria-label="Language"
      >
        <button
          type="button"
          data-lang="uk"
          class="lang-btn rounded-full px-3 py-1 text-cream transition data-[active=true]:bg-gold-bright data-[active=true]:text-ink"
          data-active="true"
          aria-pressed="true"
        >
          UA
        </button>
        <button
          type="button"
          data-lang="ru"
          class="lang-btn rounded-full px-3 py-1 text-cream/70 transition hover:text-cream data-[active=true]:bg-gold-bright data-[active=true]:text-ink"
          aria-pressed="false"
        >
          RU
        </button>
      </div>

      <!-- Telegram CTA -->
      <a
        href={site.bot.url}
        target="_blank"
        rel="noopener"
        class="hidden items-center gap-2 rounded-full border border-cream/25 bg-white/5 px-4 py-2 text-[11px] font-medium uppercase tracking-widest text-cream backdrop-blur transition hover:border-cream/60 hover:bg-white/10 md:inline-flex"
      >
        Telegram
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7V15" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        id="mobile-menu-toggle"
        aria-label="Меню"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-cream/25 bg-white/5 text-cream backdrop-blur md:hidden"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    hidden
    class="mx-6 mt-2 rounded-2xl border border-cream/15 bg-plum-deep/95 p-4 backdrop-blur-xl md:hidden"
  >
    <nav class="flex flex-col divide-y divide-cream/10">
      {nav.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <a
            href={href}
            class:list={[
              'flex items-center justify-between px-2 py-3 text-sm font-medium tracking-wide',
              active ? 'text-gold-bright' : 'text-cream/80',
            ]}
          >
            {label}
            {active && <span class="text-xs uppercase tracking-widest text-gold-bright/70">Зараз</span>}
          </a>
        );
      })}
    </nav>
    <div class="mt-4 flex items-center justify-between gap-3 pt-4 border-t border-cream/10">
      <div
        class="inline-flex items-center gap-1 rounded-full border border-cream/20 bg-white/5 p-1 text-[11px] font-semibold uppercase tracking-widest"
        role="group"
        aria-label="Language"
      >
        <button type="button" data-lang="uk" data-active="true" aria-pressed="true" class="lang-btn rounded-full px-3 py-1 text-cream transition data-[active=true]:bg-gold-bright data-[active=true]:text-ink">UA</button>
        <button type="button" data-lang="ru" aria-pressed="false" class="lang-btn rounded-full px-3 py-1 text-cream/70 transition hover:text-cream data-[active=true]:bg-gold-bright data-[active=true]:text-ink">RU</button>
      </div>
      <a href={site.bot.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full border border-cream/25 bg-white/5 px-4 py-2 text-[11px] font-medium uppercase tracking-widest text-cream">Telegram</a>
    </div>
  </div>
</header>

<!-- Toast for not-yet-translated locales -->
<div
  id="lang-toast"
  role="status"
  aria-live="polite"
  hidden
  class="fixed bottom-6 left-1/2 z-[100] -translate-x-1/2 rounded-full border border-gold-bright/40 bg-ink px-5 py-3 text-xs font-medium uppercase tracking-widest text-cream shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)]"
>
  Російська версія — скоро
</div>

<script>
  const STORAGE_KEY = 'li-astrology.locale';
  const DEFAULT_LOCALE = 'uk';
  const AVAILABLE: Record<string, boolean> = { uk: true, ru: false };

  const stored = (() => {
    try { return localStorage.getItem(STORAGE_KEY) || DEFAULT_LOCALE; } catch { return DEFAULT_LOCALE; }
  })();

  const setActive = (locale: string) => {
    document.documentElement.setAttribute('lang', locale === 'ru' ? 'ru' : 'uk');
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      const match = btn.dataset.lang === locale;
      btn.dataset.active = match ? 'true' : 'false';
      btn.setAttribute('aria-pressed', match ? 'true' : 'false');
    });
  };

  setActive(stored);

  const showToast = (msg?: string) => {
    const toast = document.getElementById('lang-toast');
    if (!toast) return;
    if (msg) toast.textContent = msg;
    toast.hidden = false;
    clearTimeout((toast as any)._t);
    (toast as any)._t = setTimeout(() => { toast.hidden = true; }, 2400);
  };

  document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = btn.dataset.lang!;
      const available = AVAILABLE[next];
      try { localStorage.setItem(STORAGE_KEY, next); } catch {}
      if (!available) {
        showToast('Російська версія — скоро');
      }
      setActive(next);
      window.dispatchEvent(new CustomEvent('locale-change', { detail: { locale: next } }));
    });
  });

  // Mobile menu
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.hasAttribute('hidden') ? true : false;
      if (open) {
        menu.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      } else {
        menu.setAttribute('hidden', '');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
