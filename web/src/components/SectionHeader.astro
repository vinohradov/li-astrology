---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, align = 'left' } = Astro.props;
---

<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  {eyebrow && (
    <div class="mb-6 flex items-center gap-3 text-xs uppercase tracking-[0.4em] text-gold-deep">
      {align !== 'center' && <span class="h-px w-10 bg-gold"></span>}
      <span>{eyebrow}</span>
      {align === 'center' && <span class="h-px w-10 bg-gold"></span>}
    </div>
  )}
  <h2 class="font-display text-[clamp(2.25rem,5vw,4rem)] leading-[1.05] tracking-tight text-balance">
    <Fragment set:html={title} />
  </h2>
</div>
