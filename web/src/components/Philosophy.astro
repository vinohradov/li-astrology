---
import SectionHeader from './SectionHeader.astro';

// 12 zodiac glyphs (Unicode), for the wheel
const zodiac = ['♈', '♉', '♊', '♋', '♌', '♍', '♎', '♏', '♐', '♑', '♒', '♓'];
---

<section class="relative overflow-hidden py-28 md:py-40">
  <!-- Warm cream backdrop -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(232,201,135,0.12),transparent_60%)]"></div>

  <div class="relative mx-auto max-w-7xl px-6 md:px-10">
    <div class="grid gap-20 md:grid-cols-2 md:items-center md:gap-24">
      <!-- Typography column -->
      <div>
        <SectionHeader
          eyebrow="Філософія"
          title="Я не ворожу.<br/>Я вчу <em class='gradient-text-gold font-display italic'>читати</em>."
        />
        <div class="mt-12 space-y-6 text-lg leading-relaxed text-ink-muted">
          <p>
            Натальна карта — це не прогноз долі та не перелік заборон. Це <span class="text-ink">інструмент саморозуміння</span>, що показує з чим ти прийшла у цей світ і як з цим жити усвідомлено.
          </p>
          <p>
            На моїх курсах немає містики, карм, «поганих» аспектів чи страху. Є логіка, структура, багато практики на реальних картах — і повага до твоєї свободи.
          </p>
        </div>

        <!-- Pull quote -->
        <blockquote class="mt-14 border-l-2 border-gold pl-8">
          <p class="font-display text-[clamp(1.75rem,3vw,2.5rem)] leading-tight text-ink">
            «Астрологія повертає тобі авторство власного життя.»
          </p>
          <footer class="mt-6 text-xs uppercase tracking-[0.3em] text-gold-deep">Анастасія Лісовська</footer>
        </blockquote>
      </div>

      <!-- Zodiac wheel composition -->
      <div class="relative mx-auto w-full max-w-[480px] aspect-square">
        <!-- Soft glow behind the wheel -->
        <div aria-hidden="true" class="absolute inset-8 rounded-full bg-[radial-gradient(circle,rgba(232,201,135,0.25)_0%,transparent_70%)] blur-2xl"></div>

        <!-- The wheel SVG -->
        <svg
          viewBox="-110 -110 220 220"
          class="relative h-full w-full animate-[float_20s_ease-in-out_infinite]"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="goldStroke" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0" stop-color="#e8c987" />
              <stop offset="1" stop-color="#8f6d31" />
            </linearGradient>
          </defs>

          <!-- Outer ring -->
          <circle cx="0" cy="0" r="100" fill="none" stroke="url(#goldStroke)" stroke-width="0.4" />
          <circle cx="0" cy="0" r="85" fill="none" stroke="url(#goldStroke)" stroke-width="0.3" />
          <circle cx="0" cy="0" r="50" fill="none" stroke="url(#goldStroke)" stroke-width="0.25" stroke-dasharray="1 3" />
          <circle cx="0" cy="0" r="14" fill="none" stroke="url(#goldStroke)" stroke-width="0.5" />

          <!-- 12 zodiac divisions -->
          {Array.from({ length: 12 }).map((_, i) => {
            const angle = (i * 30 - 90) * Math.PI / 180;
            const x1 = Math.cos(angle) * 85;
            const y1 = Math.sin(angle) * 85;
            const x2 = Math.cos(angle) * 100;
            const y2 = Math.sin(angle) * 100;
            return (
              <line x1={x1} y1={y1} x2={x2} y2={y2} stroke="url(#goldStroke)" stroke-width="0.3" />
            );
          })}

          <!-- Zodiac glyphs -->
          {zodiac.map((glyph, i) => {
            const angle = (i * 30 - 75) * Math.PI / 180;
            const r = 92.5;
            const x = Math.cos(angle) * r;
            const y = Math.sin(angle) * r;
            return (
              <text
                x={x}
                y={y}
                text-anchor="middle"
                dominant-baseline="middle"
                fill="#c9a25a"
                font-size="7"
                font-family="serif"
              >{glyph}</text>
            );
          })}

          <!-- Cardinal points dots -->
          {[0, 90, 180, 270].map((deg) => {
            const rad = (deg - 90) * Math.PI / 180;
            const x = Math.cos(rad) * 50;
            const y = Math.sin(rad) * 50;
            return (
              <circle cx={x} cy={y} r="1" fill="#c9a25a" />
            );
          })}

          <!-- Center star -->
          <g>
            <text x="0" y="0" text-anchor="middle" dominant-baseline="middle" fill="#c9a25a" font-size="16" font-family="serif">✦</text>
          </g>
        </svg>

        <!-- Floating ornaments -->
        <div aria-hidden="true" class="pointer-events-none absolute inset-0">
          <span class="absolute -left-4 top-1/3 text-3xl text-gold-deep/40 animate-[float_7s_ease-in-out_infinite]" style="font-family: serif;">☉</span>
          <span class="absolute -right-2 bottom-1/4 text-4xl text-gold-deep/35 animate-[float_9s_ease-in-out_infinite_1s]" style="font-family: serif;">☽</span>
        </div>

        <!-- Caption under wheel -->
        <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 whitespace-nowrap text-[10px] uppercase tracking-[0.4em] text-gold-deep">
          ✦ Zodiacus ✦
        </div>
      </div>
    </div>

    <!-- Trust markers strip -->
    <div class="mt-24 grid gap-8 border-t border-ink/10 pt-12 md:grid-cols-3">
      <div>
        <div class="font-display text-4xl gradient-text-gold">10+ років</div>
        <div class="mt-2 text-sm text-ink-muted">у професії, від перших консультацій до викладання</div>
      </div>
      <div>
        <div class="font-display text-4xl gradient-text-gold">3 000+</div>
        <div class="mt-2 text-sm text-ink-muted">індивідуальних консультацій з клієнтами</div>
      </div>
      <div>
        <div class="font-display text-4xl gradient-text-gold">Сотні</div>
        <div class="mt-2 text-sm text-ink-muted">випускниць, які впевнено читають карту самі</div>
      </div>
    </div>
  </div>
</section>
