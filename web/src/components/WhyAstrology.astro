---
import SectionHeader from './SectionHeader.astro';

const reasons = [
  {
    title: 'Розібратися в собі',
    text: 'Астрологія допомагає зрозуміти, хто ти є насправді і чого справді хочеш від життя. Які твої сильні сторони, де ти витрачаєш енергію даремно — і куди, навпаки, варто вкладати сили, щоб це давало результат.',
  },
  {
    title: 'Знайти своє місце і покликання',
    text: 'Якщо відчуваєш, що живеш «не своїм» життям або не розумієш, навіщо все це — натальна карта дає чіткі та конкретні відповіді. Але навіть це не головне. Головне, що розуміючи себе глибше, ти починаєш інакше дивитися на життя, на людей, на труднощі.',
  },
  {
    title: 'Знижувати ризики складних ситуацій',
    text: 'Астрологія не позбавляє нас труднощів, але дозволяє їх мінімізувати, зрозуміти їх сенс і пройти з мінімальними втратами.',
  },
  {
    title: 'Побудувати нову професію',
    text: 'Попит на астрологів стабільно зростає — бо люди звертаються за допомогою в найважливіші моменти: коли не розуміють себе, стоять перед складним вибором або шукають своє призначення. Астролог потрібен завжди. Це реальна професія з реальним доходом.',
  },
  {
    title: 'Підсилити те, чим вже займаєшся',
    text: 'Ти таролог, психолог, коуч або нумеролог? Астрологія стане додатковим інструментом, який зробить твою роботу з людьми більш глибшою і точнішою.',
  },
  {
    title: 'Перестати дивуватися, чому світ такий, який він є',
    text: 'Чому одні люди легко досягають свого, а інші — ні. Чому одні стосунки дають сили, а інші забирають. Чому в певні періоди все йде не так, як хочеться. Астрологія дає на це цілком логічні відповіді. Ти починаєш бачити закономірності там, де раніше здавався хаос — і це змінює ставлення до себе, до інших людей і до життя загалом.',
  },
];
---

<section class="relative py-28 md:py-40 bg-cream-dim/40">
  <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(232,201,135,0.1),transparent_60%)]"></div>

  <div class="relative mx-auto max-w-6xl px-6 md:px-10">
    <SectionHeader
      eyebrow="Навіщо"
      title="Навіщо астрологія<br/><em class='gradient-text-gold font-display italic'>сучасній людині</em>?"
      align="center"
    />

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:gap-8">
      {reasons.map((r) => (
        <div class="group relative overflow-hidden rounded-3xl border border-ink/5 bg-cream p-8 transition hover:border-gold/40 md:p-10">
          <div class="mb-4 font-display text-2xl text-gold-deep">✶</div>
          <h3 class="font-display text-xl leading-tight md:text-2xl">{r.title}</h3>
          <p class="mt-4 text-base leading-relaxed text-ink-muted">{r.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
