---
import { site } from '@/config/site';
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden gradient-night text-cream">
  <div class="noise-overlay absolute inset-0 opacity-[0.03]"></div>

  <!-- Ornamental top divider -->
  <div aria-hidden="true" class="relative mx-auto flex max-w-7xl items-center gap-6 px-6 pt-16 md:px-10">
    <span class="h-px flex-1 bg-linear-to-r from-transparent via-gold/40 to-gold/20"></span>
    <span class="font-display text-xl text-gold-bright">✦</span>
    <span class="h-px flex-1 bg-linear-to-l from-transparent via-gold/40 to-gold/20"></span>
  </div>

  <div class="relative mx-auto max-w-7xl px-6 pt-16 pb-10 md:px-10">
    <div class="grid gap-16 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <!-- Brand + pitch + socials + contact -->
      <div>
        <div class="flex items-center gap-3">
          <Logo class="h-10 w-10" />
          <span class="font-display text-2xl tracking-wide">Li Astrology</span>
        </div>
        <p class="mt-6 max-w-sm text-sm leading-relaxed text-cream/70">
          Астрологія як мова розуміння себе. Курси та інтенсиви від Анастасії Лісовської — без містики та езотеричних шаблонів.
        </p>

        <div class="mt-6 space-y-1.5 text-sm text-cream/70">
          <div>
            <a href={`mailto:${site.contact.email}`} class="group inline-flex items-center gap-2 transition hover:text-gold-bright">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6" />
              </svg>
              <span>{site.contact.email}</span>
            </a>
          </div>
        </div>

        <div class="mt-6 flex gap-4">
          <a href={site.bot.url} target="_blank" rel="noopener" class="group flex items-center gap-2 text-sm text-cream/80 transition hover:text-gold-bright">
            <span>Telegram</span>
            <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7V15" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href={site.instagram} target="_blank" rel="noopener" class="group flex items-center gap-2 text-sm text-cream/80 transition hover:text-gold-bright">
            <span>Instagram</span>
            <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7V15" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <!-- Courses -->
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-gold-bright">Курси</div>
        <ul class="mt-6 space-y-3 text-sm text-cream/80">
          <li><a href="/intensiv/" class="transition hover:text-cream">Інтенсив «Астрологія з 0»</a></li>
          <li><a href="/aspekty/" class="transition hover:text-cream">Аспекти натальної карти</a></li>
          <li><a href="/course/" class="transition hover:text-cream">Повний курс</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-gold-bright">Правова інформація</div>
        <ul class="mt-6 space-y-3 text-sm text-cream/80">
          <li><a href="/legal/offer/" class="transition hover:text-cream">Публічна оферта</a></li>
          <li><a href="/legal/refund/" class="transition hover:text-cream">Повернення коштів</a></li>
          <li><a href="/legal/privacy/" class="transition hover:text-cream">Конфіденційність</a></li>
          <li><a href="/legal/terms/" class="transition hover:text-cream">Правила користування</a></li>
        </ul>
      </div>

      <!-- Payment info -->
      <div>
        <div class="text-xs uppercase tracking-[0.25em] text-gold-bright">Оплата</div>
        <p class="mt-6 text-sm leading-relaxed text-cream/70">
          Безпечна оплата картами Visa та Mastercard. Обробляється сертифікованою платіжною системою WayForPay.
        </p>
        <div class="mt-5 flex items-center gap-2">
          <!-- Visa -->
          <div class="flex h-7 w-12 items-center justify-center rounded-md border border-cream/15 bg-white/90 text-[11px] font-bold tracking-wide text-[#1a1f71]">
            VISA
          </div>
          <!-- Mastercard (abstract disc mark) -->
          <div class="flex h-7 w-12 items-center justify-center rounded-md border border-cream/15 bg-white/90">
            <div class="flex items-center">
              <span class="block h-4 w-4 rounded-full bg-[#eb001b]"></span>
              <span class="-ml-1.5 block h-4 w-4 rounded-full bg-[#f79e1b] mix-blend-multiply"></span>
            </div>
          </div>
          <!-- WayForPay chip -->
          <div class="flex h-7 items-center rounded-md border border-cream/15 bg-white/90 px-2 text-[10px] font-semibold uppercase tracking-wider text-ink">
            WayForPay
          </div>
        </div>
        <div class="mt-5 flex items-center gap-2 text-[11px] uppercase tracking-[0.25em] text-cream/50">
          <svg class="h-3.5 w-3.5 text-gold-bright" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
          <span>PCI DSS · SSL</span>
        </div>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="mt-16 flex flex-col items-start gap-3 border-t border-cream/10 pt-8 text-xs text-cream/50 md:flex-row md:items-center md:justify-between">
      <div class="space-y-1">
        <div>© {year} {site.name}. {site.legal.entity}</div>
        <div class="text-cream/35">{site.legal.entityFull}</div>
      </div>
      <div class="flex items-center gap-2 font-display tracking-[0.3em] uppercase text-cream/40">
        <span>Made with</span>
        <span class="text-gold-bright">✦</span>
        <span>in Ukraine</span>
      </div>
    </div>
  </div>
</footer>
