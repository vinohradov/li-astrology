---
interface Props {
  class?: string;
  title?: string;
}
const { class: className = '', title = 'Li Astrology' } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 48 48"
  class:list={['block', className]}
  role="img"
  aria-label={title}
>
  <defs>
    <linearGradient id="liLogoGold" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#f5d98f" />
      <stop offset="55%" stop-color="#e8c987" />
      <stop offset="100%" stop-color="#c9a25a" />
    </linearGradient>
    <mask id="liLogoMoonMask">
      <rect x="0" y="0" width="48" height="48" fill="white" />
      <circle cx="31" cy="20" r="13" fill="black" />
    </mask>
  </defs>

  <!-- Outer thin zodiac ring -->
  <circle cx="24" cy="24" r="22" fill="none" stroke="url(#liLogoGold)" stroke-width="0.9" opacity="0.55" />

  <!-- Inner ring -->
  <circle cx="24" cy="24" r="18" fill="none" stroke="url(#liLogoGold)" stroke-width="0.6" opacity="0.35" />

  <!-- Crescent moon -->
  <circle cx="22" cy="24" r="11" fill="url(#liLogoGold)" mask="url(#liLogoMoonMask)" />

  <!-- Small star -->
  <g transform="translate(33 14)">
    <path
      d="M0 -3.2 L0.9 -0.9 L3.2 0 L0.9 0.9 L0 3.2 L-0.9 0.9 L-3.2 0 L-0.9 -0.9 Z"
      fill="url(#liLogoGold)"
    />
  </g>

  <!-- Tick marks on zodiac ring (12) -->
  {Array.from({ length: 12 }).map((_, i) => {
    const angle = (i * 30 - 90) * Math.PI / 180;
    const inner = 20;
    const outer = 22;
    return (
      <line
        x1={24 + Math.cos(angle) * inner}
        y1={24 + Math.sin(angle) * inner}
        x2={24 + Math.cos(angle) * outer}
        y2={24 + Math.sin(angle) * outer}
        stroke="url(#liLogoGold)"
        stroke-width="0.5"
        opacity="0.4"
      />
    );
  })}
</svg>
