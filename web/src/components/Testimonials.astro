---
import SectionHeader from './SectionHeader.astro';
import { site } from '@/config/site';

const testimonials = [
  {
    quote: 'Я нарешті зрозуміла, чому в одних ситуаціях сильна, а в інших — застрягаю. Курс — чистий золото.',
    author: 'Марія К.',
    role: 'Випускниця інтенсиву',
  },
  {
    quote: 'Анастасія пояснює складне так, що після уроку хочеться одразу пробувати на своїй карті. Без «ахів і охів», тільки зміст.',
    author: 'Ольга Р.',
    role: 'Тариф Аспекти',
  },
  {
    quote: 'Прийшла з повним скептицизмом. Пішла з розумінням, що астрологія — це про мислення, а не про містику.',
    author: 'Катерина Л.',
    role: 'Випускниця курсу',
  },
];
---

<section class="relative py-28 md:py-40 gradient-night text-cream overflow-hidden">
  <div class="noise-overlay absolute inset-0 opacity-[0.03]"></div>

  <div class="relative mx-auto max-w-7xl px-6 md:px-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeader
        eyebrow="Відгуки"
        title="Те, що <em class='gradient-text-gold font-display italic'>лишається</em><br/>після курсу."
      />
      <a href={site.instagram} target="_blank" rel="noopener" class="group inline-flex items-center gap-2 self-start text-sm text-cream/70 transition hover:text-cream md:self-end">
        <span>Більше відгуків в Instagram</span>
        <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H9M17 7V15" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="mt-20 grid gap-8 md:grid-cols-3">
      {testimonials.map((t, i) => (
        <figure class:list={[
          'relative rounded-[2rem] border border-cream/10 bg-linear-to-b from-white/[0.03] to-white/[0.01] p-10 backdrop-blur-sm transition hover:border-gold-bright/30',
          i === 1 && 'md:translate-y-8',
        ]}>
          <div class="mb-6 font-display text-6xl leading-none text-gold-bright/50">“</div>
          <blockquote class="text-lg leading-relaxed text-cream/90">{t.quote}</blockquote>
          <figcaption class="mt-8 border-t border-cream/10 pt-5">
            <div class="font-display text-xl text-cream">{t.author}</div>
            <div class="mt-1 text-[11px] uppercase tracking-[0.3em] text-cream/50">{t.role}</div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
