---
import Layout from '@/layouts/Layout.astro';
import { site, products, type ProductSlug } from '@/config/site';

const rawProduct = Astro.url.searchParams.get('product') as ProductSlug | null;
const orderId = Astro.url.searchParams.get('order_id') ?? '';
const product = rawProduct && products[rawProduct] ? products[rawProduct] : null;

const retryHref = product?.href ?? '/';
---

<Layout
  title="Оплата не пройшла — Li Astrology"
  description="Щось пішло не так під час оплати. Спробуйте ще раз або напишіть нам."
  noindex
>
  <section class="relative isolate min-h-screen overflow-hidden gradient-night text-cream">
    <div class="noise-overlay absolute inset-0"></div>
    <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(232,201,135,0.1)_0%,transparent_65%)]"></div>

    <div class="relative mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center px-6 py-24 text-center md:px-10">
      <!-- Muted warning icon -->
      <div class="relative mb-10 flex h-24 w-24 items-center justify-center rounded-full border border-cream/20 bg-white/5 backdrop-blur">
        <svg class="h-10 w-10 text-cream/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="8" x2="12" y2="12" stroke-linecap="round" />
          <line x1="12" y1="16" x2="12.01" y2="16" stroke-linecap="round" />
        </svg>
      </div>

      <div class="mb-6 flex items-center gap-3 text-xs uppercase tracking-[0.4em] text-cream/60">
        <span class="h-px w-10 bg-cream/30"></span>
        <span>Оплата не пройшла</span>
        <span class="h-px w-10 bg-cream/30"></span>
      </div>

      <h1 class="font-display text-[clamp(2.25rem,5vw,4rem)] leading-[1.05] tracking-tight text-balance">
        Щось пішло <em class="gradient-text-gold font-display italic">не так</em>.
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-cream/75 md:text-lg">
        Оплату не було завершено. Кошти з картки не списані. Ви можете спробувати ще раз або повідомити нас — ми допоможемо.
      </p>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
        <a
          href={retryHref}
          class="group inline-flex items-center gap-3 rounded-full bg-gold-bright px-8 py-4 text-sm font-semibold uppercase tracking-[0.2em] text-ink transition duration-300 hover:bg-gold"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 12a9 9 0 1 0 3.7-7.3L3 8m0-5v5h5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Спробувати ще раз</span>
        </a>
        <a
          href={`mailto:${site.contact.email}?subject=${encodeURIComponent(`Проблема з оплатою${orderId ? ` — замовлення ${orderId}` : ''}`)}`}
          class="inline-flex items-center gap-2 rounded-full border border-cream/25 px-6 py-3 text-xs uppercase tracking-[0.25em] text-cream/80 transition hover:border-cream/60 hover:text-cream"
        >
          Написати нам
        </a>
      </div>

      <!-- What might have happened -->
      <div class="mx-auto mt-16 grid w-full max-w-xl gap-3 text-left">
        <details class="group rounded-2xl border border-cream/10 bg-white/[0.02] p-5">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-medium text-cream">
            Що могло статися?
            <span aria-hidden="true" class="flex h-7 w-7 items-center justify-center rounded-full border border-cream/20 text-cream transition group-open:rotate-45">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
            </span>
          </summary>
          <ul class="mt-4 space-y-2 text-sm leading-relaxed text-cream/70">
            <li>• Ви відмінили оплату на сторінці банку.</li>
            <li>• Банк тимчасово відхилив транзакцію (обмеження за картою, ліміт, 3D Secure).</li>
            <li>• На картці недостатньо коштів.</li>
            <li>• Тимчасовий збій зв'язку з платіжною системою.</li>
          </ul>
        </details>
      </div>

      {orderId && (
        <p class="mt-14 text-xs uppercase tracking-[0.25em] text-cream/40">
          Номер замовлення: <span class="font-mono text-cream/70">{orderId}</span>
        </p>
      )}

      <p class="mt-6 text-xs text-cream/50">
        Ми допоможемо розібратися. Пишіть на
        <a href={`mailto:${site.contact.email}`} class="text-gold-bright underline-offset-4 hover:underline">
          {site.contact.email}
        </a>
      </p>
    </div>
  </section>
</Layout>
