---
import Layout from '@/layouts/Layout.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import ProgramAccordion from '@/components/ProgramAccordion.tsx';
import InstagramReview from '@/components/InstagramReview.astro';
import type { InstagramReviewData } from '@/components/InstagramReview.astro';
import { products, site } from '@/config/site';

const basic = products['astro-z-0'];
const pro = products['astro-z-0-pro'];

const buyBasicHref = `${site.bot.url}?start=buy_astro-z-0`;
const waitlistHref = `${site.bot.url}?start=waitlist_course`;

const audience = [
  { title: 'Для себе', text: 'Хочеш навчитися самостійно читати свою натальну карту і розуміти себе глибше — без містики і поверхневих трактувань.', glyph: '☉' },
  { title: 'На старті', text: 'Ти лише починаєш і знаєш астрологію з книг чи соцмереж, але хочеш системно розібратися з нуля.', glyph: '☽' },
  { title: 'Є знання, але немає впевненості', text: 'Ти вже щось знаєш, але сумніваєшся у своїй компетенції і боїшся консультувати.', glyph: '♀' },
  { title: 'У пошуку відповідей', text: 'Шукаєш відповіді на глибші питання: хто ти, у чому твоя роль і як реалізувати себе. Хочеш бачити життя як цілісну систему та приймати усвідомлені рішення.', glyph: '♃' },
  { title: 'Нова професія', text: 'Мрієш опанувати астрологію як професію та заробляти, займаючись улюбленою справою.', glyph: '♄' },
  { title: 'Для практики', text: 'Ти нумеролог, таролог, коуч. Хочеш впевнено працювати з людьми і вийти на новий рівень консультацій.', glyph: '♆' },
];

const whyCourse = [
  {
    title: 'Закохаєшся в астрологію',
    text: 'Мета цього курсу — дати тобі об\'ємне, глибоке бачення світу та себе в ньому. А замість загальних гороскопів ти опануєш системний підхід до астрології.',
  },
  {
    title: 'Повноцінна картина',
    text: '12 уроків проведуть вас від базових принципів до цілісного розуміння натальної карти. Жодна тема не залишиться поза увагою.',
  },
  {
    title: 'Готові до практики',
    text: 'Еталонний розбір, практичні завдання та приклад консультації. У результаті ви впевнено працюєте з кожною натальною картою.',
  },
];

const program = [
  { num: '🎧', title: 'Подарунки: аудіо-подкасти', text: 'Аудіо-подкасти про роботу зі станом і внутрішнє налаштування перед консультаціями.' },
  { num: '01', title: 'Філософія астрології', text: 'Правила навчання та базові принципи. Дуальність енергій, рівні проживання карти, роль астролога.' },
  { num: '02', title: 'Знаки зодіаку', text: 'Цикл розвитку знаків, осі, стихії та хрести. Як визначити темперамент людини + домашні завдання для самоперевірки.' },
  { num: '03', title: 'Елементи натальної карти', text: 'Градуси, куспіди, планети, аспекти. Покроковий алгоритм аналізу карти + домашні завдання для самоперевірки.' },
  { num: '🎁', title: 'Подарунок: Сонце і Місяць', text: 'Ядро особистості — що формує характер, емоції, реакції. Практика на реальних картах + домашні завдання для самоперевірки.' },
  { num: '04', title: 'Особисті планети', text: 'Меркурій — особливості комунікації або як домовитися з усіма. Венера — кохання, задоволення та гроші. Марс — у чому ваша сила та мотивація. Ретроградність особистих планет.' },
  { num: '05', title: 'Соціальні планети', text: 'Юпітер — ваші цінності та зона удачі. Сатурн — ваші життєві пріоритети, дисципліна та зона відповідальності.' },
  { num: '06', title: 'Вищі планети', text: 'Уран — де варто залишати місце для спонтанності та діяти нестандартно. Нептун — де варто спиратися на інтуїцію. Плутон — де варто ініціювати глибинні зміни; зона вашої сили та впливу.' },
  { num: '07', title: 'Доми (поля гороскопу)', text: 'Доми показують сфери життя, де реалізується енергія планет. Вчимося читати ці сфери та розуміти, де саме відбуваються події.' },
  { num: '08', title: 'Управителі домів', text: 'Управителі домів показують, як взаємодіють сфери життя між собою. Вчимося бачити ці зв\'язки в натальній карті.' },
  { num: '09', title: 'Аспекти', text: 'Аспекти показують, як взаємодіють планети між собою. Вчимося їх читати та розуміти вплив на характер і події. Цей урок також доступний і як окремий міні-курс «Аспекти».' },
  { num: '10', title: 'Синтез карти і робота з протиріччями', text: 'Навчимось поєднувати всі показники карти в єдину систему та бачити за ними живу людину, а не просто набір символів.' },
  { num: '11', title: 'Кармічні символи та призначення', text: 'Розбираємо кармічні показники карти та вчимося визначати вектор розвитку і призначення людини.' },
  { num: '📋', title: 'Методички', text: 'Кожен урок супроводжується детальною методичкою, яка залишається у вас назавжди. Уся потрібна інформація для консультацій буде завжди під рукою.' },
  { num: '🎁', title: 'Бонус: еталонний розбір карти', text: 'Ви отримуєте готову структуру письмового розбору, на яку зможете впевнено спиратися на початку роботи з клієнтами. Завдяки великій кількості прикладів у курсі, до кінця навчання ви вже зможете впевнено аналізувати карти самостійно.' },
];

const proExtras = [
  { title: 'Типи клієнтів', text: 'Як зрозуміти адекватність клієнта при першому контакті. Кому відмовляти — і як.' },
  { title: 'Робота із запитом', text: 'Як виявити справжній запит клієнта. Техніки роботи з хвилюванням перед консультацією.' },
  { title: 'Секрети консультування', text: 'Часті помилки. Як упевнено відповідати на незручні запитання. Етика астролога.' },
  { title: 'Негативні відгуки', text: 'Як працювати зі складним зворотним зв\'язком. Відпустити страх критики.' },
  { title: 'Особистий бренд', text: 'Як грамотно подавати себе як особистість і як професіонала. На чому обов\'язково робити акцент.' },
  { title: 'Ціноутворення', text: 'Цільова аудиторія, болі, потреби. Як доносити цінність послуг і грамотно виставляти ціни.' },
];

const basicItems = [
  'Усі 12 уроків повного курсу',
  'Приклад готової консультації',
  'Аудіо-подкасти про роботу зі станом',
  'Методички до кожного уроку — назавжди',
  'Бонус: еталонний розбір натальної карти',
  'Домашні завдання для самоперевірки',
  'Доступ до матеріалів назавжди',
];

const proItems = [
  'Все, що входить у тариф «Для себе»',
  'Блок «Як консультувати» — 6 окремих модулів про особливості роботи з клієнтами',
  'Доступ до матеріалів назавжди',
];

const reviews: InstagramReviewData[] = [
  {
    handle: '@olena_astro',
    messages: [
      {
        text: `в мене тільки одне велике питання, чому я не зустріла вас раніше, ще коли тільки починала! якби я одразу пішла вчитися до вас, я б не прожила багато тих труднощів, з якими стикалася в консультуванні. Тому що в жодній школі не давали такої глибокої інформації, як у вас!
Вибачте, що так багато тексту , просто хочу сказати, що ви мій найкращий вчитель! Від щирого серця дякую за вашу працю.`,
        reactions: ['❤️'],
      },
    ],
  },
  {
    handle: '@marichka_l',
    messages: [
      {
        text: `Анастасія, доброго дня! Хочу подякувати вам за те, що ви робите. Щойно закінчила у вас повноцінне навчання і отримала безліч корисних знань.
А ваш майстер курс з розбору натальних карт і приклади як консультувати людей це просто бомба! Чесно, це вищий рівень! Я проходила багато навчань з астрології, але щось усе одно не складалося в голові або просто не хотіло складатися.
Але спостерігаючи за тим, як ви розбираєте карту, ніби чарівним чином усі знання вибудувалися в єдине ціле 🎯
Теперь я точно знаю, хто я, яка я, які і де мені розкривати свій потенціал. Почала над цим працювати 🌸
Майже все життя я бігла від себе, а зараз багато що зрозуміла і йду до себе завдяки вам 💙💛
Дякую, що ви є і за те, чим ви займаєтесь))`,
        reactions: ['❤️'],
      },
    ],
  },
  {
    handle: '@nataly_t',
    messages: [
      {
        text: `Анастасіє, хочу залишити вам відгук про ваше навчання 😉
Ви геніальний викладач, усім би таких вчителів! Складається враження, що ви викладаєтеся до останньої краплі. Під час навчання я не переставала захоплюватися якістю подачі матеріалу та обсягом знань.
Кожна ваша лекція це мотивуючий поштовх практикувати і бути впевненою у собі 🤞🏼
Щоразу, коли я починала сумніватися в собі і лякалася кількості інформації, яку потрібно опанувати, ви знову і знову повторювали, що все нормально і все вийде) Загалом, я в захваті!!!`,
        reactions: ['❤️'],
      },
    ],
  },
  {
    handle: '@valeria_k',
    messages: [
      {
        text: `Настю, вітаю! Ділюся з вами враженнями про ваше навчання 💖

Враження тільки позитивні! Давно замислювалася про проходження курсу з астрології, і вибір викладача був зроблений одразу 🤗

Після наших з вами консультацій я інших навіть не розглядала, ваша енергетика мені дуже близька, і все, що ви говорите на 100% мені близьке.`,
        reactions: ['❤️'],
      },
      {
        text: `Щодо самого курсу: з точки зору подачі матеріалу все шикарно, від простого до складного, при цьому складні теми зачіпаються на початку для ознайомлення, а потім розгортаються наприкінці. Це дуже круто! Мені сподобався такий підхід.
Дуже подобається слухати вас))
Ви так красиво говорите.
Загалом, викладач найвищого рівня! 👏`,
        reactions: ['❤️'],
      },
      {
        text: `Курс я проходила для себе, але вже вдалося провести кілька консультацій знайомим і яке було моє здивування, коли відгуки були лише позитивні! Це дуже надихає продовжувати далі і бути сміливішою. Як ви вчили))
Дякую! 🙏🥰`,
